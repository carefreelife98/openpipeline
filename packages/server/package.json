{
  "name": "@openworkflow/server",
  "version": "0.1.0",
  "description": "Transport-agnostic HTTP + SSE handlers for OpenWorkflow, with a tiny Node http adapter.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@openworkflow/core": "workspace:*",
    "@openworkflow/runtime": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
